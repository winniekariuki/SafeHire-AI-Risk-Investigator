# Copy to .env and use with: docker compose --env-file .env up --build

# Must match FastAPI ``/api`` prefix (local Docker: backend:8000 → http://localhost:8000/api)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Web image build args + runtime
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_SECRET_KEY=

# API
OPENAI_API_KEY=
